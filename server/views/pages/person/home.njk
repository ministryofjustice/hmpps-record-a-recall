{% extends "../../partials/prisonerBannerLayout.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "hmpps/components/court-cases-release-dates/sub-navigation/macro.njk" import subNavigation %}
{% from "hmpps/components/court-cases-release-dates/things-to-do/macro.njk" import thingsToDo %}
{% from "partials/components/recall-card/macro.njk" import recallCard %}
{% from "partials/unknown-pre-recall-sentence-type-panel.njk" import unknownPreRecallSentenceTypePanel %}

{% set pageTitle = applicationName + " - person home" %}
{% set pageId = "person-home" %}

{% block beforeContent %}
  {{ super() }}
  {{ subNavigation(serviceDefinitions.services, 'recalls') }}
{% endblock %}

{% block content %}
{% set hasRecalls = recalls and recalls.length %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-xl">Recalls</h1>
    {{ thingsToDo(serviceDefinitions, 'recalls') }}
    {% if not hasRecalls %}
      <p data-qa="no-recalls-hint">There are no recalls recorded.</p>
    {% endif %}

    {% if unknownPreRecallJourneyComplete %} 
      <div data-qa="unknown-pre-recall-panel">
        {{ unknownPreRecallSentenceTypePanel(nomsId) }}
      </div>
    {% else %}

      {{ govukButton({
        classes: "govuk-button--secondary",
        text: "Record a recall",
        preventDoubleClick: true,
        href: '/person/' + nomsId + '/recall/create/start',
        attributes: { 'data-qa': 'create-new-recall-btn' }
      }) }}
    {% endif %}
      </div>
</div>
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds govuk-!-margin-bottom-0">
    {% for recall in recalls %}
      {{ recallCard(recall, serviceDefinitions) }}
    {% endfor %}
  </div>
</div>
 
{% endblock %}
