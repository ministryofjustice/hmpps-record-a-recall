{% extends "./prisonerBannerBackLayout.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}

{% set title = "You cant record a recall" %}
{% set pageTitle = applicationName + " - " + title %}
{% set showCancelLink = false %}

{% block pageContent %}
  <h1 class="govuk-heading-xl" id="not-possible-heading" data-qa="penultimate-errors-intercept-heading">You can record a recall, but some of the information might be wrong</h1>
  <p class="govuk-body" data-qa="validation-message">
  {% if messages.length == 1 %}This is because {{ messages | first | lowercaseFirstLetter }}</p>
  {% else %}This is because:
    <ul class="govuk-list govuk-list--bullet">
      {% for message in messages %}
        <li data-qa="multi-validation-message-{{ loop.index }}">{{ message }}</li>
      {% endfor %}
    </ul>
  {% endif %}

  <p class="govuk-body">If this court case information is not relevant, it will not impact the recall or the calculation.</p>
  <p class="govuk-body">If this court case is recalled, you cannot perform a calculation until the information is updated in DPS.</p>

  <div class="govuk-button-group govuk-!-margin-top-5">
    {{ govukButton({
      text: "Continue",
      preventDoubleClick: true,
      href: continueUrl,
      attributes: { id: "continue-button", "data-qa": "continue-btn" }
    }) }}
    {{ govukButton({
      text: "Cancel",
      classes: "govuk-button--secondary",
      preventDoubleClick: true,
      href: cancelUrl,
      attributes: { id: "cancel-button", "data-qa": "cancel-btn" }
    }) }}
  </div>
{% endblock %}
